# Скопируйте этот файл в .env и заполните своими значениями:
#   cp .env.example .env
#
# Файл .env добавлен в .gitignore и никогда не попадёт в репозиторий.

# ─── Веб-сервер мониторинга ───────────────────────────────────────────────────

# Порт на котором слушает монитор
PORT=8080

# Логин и пароль для входа в дашборд мониторинга
APP_USERNAME=your_dashboard_login
APP_PASSWORD=your_dashboard_password

# Секрет для подписи сессионных cookie (любая случайная строка, мин. 32 символа)
# Сгенерировать: openssl rand -hex 32
SESSION_SECRET=replace_with_random_32char_string

# ─── TLS-сертификаты ──────────────────────────────────────────────────────────

TLS_CERT=/path/to/fullchain.pem
TLS_KEY=/path/to/privkey.pem

# ─── Подключение к панели 3X-UI ───────────────────────────────────────────────

# Полный URL панели включая порт
XUI_URL=https://your-domain.com:808

# Логин и пароль от панели 3X-UI
XUI_USER=your_3xui_login
XUI_PASS=your_3xui_password

# Скопируйте этот файл в .env и заполните своими значениями:
#   cp .env.example .env
#
# Файл .env добавлен в .gitignore и никогда не попадёт в репозиторий.

# ─── Веб-сервер мониторинга ───────────────────────────────────────────────────

# Порт на котором слушает монитор
PORT=8080

# Логин и пароль для входа в дашборд мониторинга
DASH_USER=your_dashboard_login
DASH_PASS=your_dashboard_password

# Секрет для подписи сессионных cookie (если не задать — генерируется автоматически)
# Сгенерировать: openssl rand -hex 32
SESSION_SECRET=

# ─── TLS (HTTPS) ──────────────────────────────────────────────────────────────

# Включить HTTPS (true/false)
HTTPS_ENABLED=false

# Пути к сертификатам (нужны только если HTTPS_ENABLED=true)
TLS_CERT=/path/to/fullchain.pem
TLS_KEY=/path/to/privkey.pem

# ─── Подключение к панели 3X-UI ───────────────────────────────────────────────

# Полный URL панели включая порт, например: http://localhost:2053
XUI_URL=http://localhost:2053

# Логин и пароль от панели 3X-UI
XUI_USER=your_3xui_login
XUI_PASS=your_3xui_password

# ─── Хранение данных ──────────────────────────────────────────────────────────

# Директория для SQLite базы данных с метриками
DATA_DIR=/var/lib/vpn-monitor

# Сколько дней хранить данные (по умолчанию 30)
RETENTION_DAYS=30
